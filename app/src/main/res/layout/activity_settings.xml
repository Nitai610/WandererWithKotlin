<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7"> <!-- Soft modern gray background matches other pages -->

    <!-- 1. Regular Text Header -->
    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Settings"
        android:textAlignment="center"
        android:textColor="#212121"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. The Settings Menu Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="48dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle">



        <!-- NEW: TEST NOTIFICATION BUTTON -->

        <!-- NEW: CLEAR HISTORY BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestNotification"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="TEST NOTIFICATION"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#1E104E"
            app:cornerRadius="16dp"
            app:elevation="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearHistory"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="CLEAR JOURNAL HISTORY"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#EF5350"
            app:cornerRadius="16dp"
            app:elevation="2dp"
            app:strokeColor="#EF5350"
            app:strokeWidth="1dp" />

        <!-- LOG OUT BUTTON (Premium white card with a red danger outline) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="LOG OUT"
            android:textColor="#EF5350"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="16dp"
            app:elevation="2dp"
            app:strokeColor="#EF5350"
            app:strokeWidth="2dp" />

    </LinearLayout>

    <!-- 3. Floating 'Pill' Back Button (Matches Journal & Stats exactly) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettingsBack"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="32dp"
        android:text="GO BACK"
        android:textColor="#212121"
        android:textStyle="bold"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_revert"
        app:iconTint="#212121"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#E0E0E0"
        app:strokeWidth="1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>