<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7"> <!-- Soft gray background matches Stats -->

    <!-- 1. Regular Text Header (Exactly like the Stats page) -->
    <TextView
        android:id="@+id/tvJournalTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="16dp"
        android:text="My Travel Journal"
        android:textAlignment="center"
        android:textColor="#212121"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. The Scrolling List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewJournal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJournalTitle" />

    <!-- 3. The Empty State Box -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJournalTitle">

        <!-- Faded Compass Icon -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="16dp"
            android:src="@android:drawable/ic_menu_compass"
            app:tint="#BDBDBD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Your journal is empty.\nStart your first adventure!"
            android:textAlignment="center"
            android:textColor="#757575"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmptyStartWalk"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="START A WALK"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="30dp" />
    </LinearLayout>

    <!-- 4. Floating 'Pill' Back Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnJournalBack"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="32dp"
        android:text="GO BACK"
        android:textColor="#212121"
        android:textStyle="bold"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_revert"
        app:iconTint="#212121"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#E0E0E0"
        app:strokeWidth="1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>